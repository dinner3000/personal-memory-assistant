# Personal Memory Assistant — Environment Variables
# Copy this to .env and fill in your values

# Journal path (leave empty to use the default: ~/personal-memory-assistant/journal/)
JOURNAL_PATH=

# Obsidian vault path (optional — if set, journal can also be your Obsidian vault)
# OBSIDIAN_VAULT_PATH=/home/user/Documents/Obsidian Vault

# Git user name/email for journal commits (optional — defaults to global git config)
# GIT_USER_NAME=
# GIT_USER_EMAIL=
